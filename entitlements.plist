<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Camera access for face recognition -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- Keychain access for storing Mac password -->
    <key>com.apple.security.keychain-access-groups</key>
    <array>
        <string>com.visionsight.daemon</string>
    </array>

    <!-- Allow sending Apple Events (for keyboard injection to unlock screen) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Required for ad-hoc signed apps to run without Gatekeeper blocking -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allows loading unsigned dylibs (needed for cv2, dlib, face_recognition) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow DYLD env vars — required for PyInstaller frozen bundles on Sonoma+ -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Allow JIT (needed by dlib/numpy on ARM for JIT-compiled routines) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
