#!/usr/bin/env python3
import sys
import os
import subprocess
import time
import signal

# Get project root (following symlinks if globally installed)
BASE_DIR = os.path.dirname(os.path.realpath(__file__))
VENV_PYTHON = os.path.join(BASE_DIR, ".venv", "bin", "python3")

# Auto-re-execute using the virtual environment's Python interpreter if it exists
if os.path.exists(VENV_PYTHON) and sys.executable != VENV_PYTHON:
    os.execv(VENV_PYTHON, [VENV_PYTHON] + sys.argv)

# Add project root to sys.path so modules can be imported
sys.path.append(BASE_DIR)

def get_running_pids():
    pids = []
    try:
        output = subprocess.check_output(["ps", "-ef"]).decode("utf-8")
        for line in output.splitlines():
            # Check for gui/app.py but exclude grep and self
            if "gui/app.py" in line and "grep" not in line and "visionsight" not in line:
                parts = line.split()
                if len(parts) > 1:
                    pids.append(int(parts[1]))
    except Exception as e:
        print(f"Error checking processes: {e}")
    return pids

def launch_gui(minimized=False):
    pids = get_running_pids()
    if pids:
        if minimized:
            print(f"VisionSight is already running (PID: {pids[0]}).")
        else:
            print(f"VisionSight is already running (PID: {pids[0]}). Sending signal to show dashboard GUI...")
            try:
                from Foundation import NSDistributedNotificationCenter
                dist_nc = NSDistributedNotificationCenter.defaultCenter()
                dist_nc.postNotificationName_object_userInfo_("com.visionsight.show_gui", None, None)
            except Exception as e:
                print(f"Error bringing GUI to front: {e}")
        return
        
    cmd = [VENV_PYTHON, os.path.join(BASE_DIR, "gui", "app.py")]
    if minimized:
        cmd.append("--tray")
        
    print(f"Launching VisionSight {'in system tray...' if minimized else 'dashboard...'}")
    subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)

def stop_daemon():
    pids = get_running_pids()
    if not pids:
        print("VisionSight is not running.")
        return
        
    for pid in pids:
        print(f"Stopping VisionSight process {pid}...")
        try:
            os.kill(pid, signal.SIGTERM)
            time.sleep(0.5)
            # Check if still running
            os.kill(pid, 0)
            os.kill(pid, signal.SIGKILL)
        except OSError:
            pass
    print("VisionSight stopped.")

def run_setup():
    setup_script = os.path.join(BASE_DIR, "setup.py")
    subprocess.run([VENV_PYTHON, setup_script])

def print_status():
    pids = get_running_pids()
    if pids:
        print(f"VisionSight protection daemon is ACTIVE (PID: {', '.join(map(str, pids))}).")
    else:
        print("VisionSight protection daemon is INACTIVE.")

def list_identities():
    import pickle
    import system.paths as paths
    encodings_path = paths.get_encodings_path()
    if not os.path.exists(encodings_path):
        print("No registered identities found.")
        return
    try:
        with open(encodings_path, "rb") as f:
            data = pickle.load(f)
            if not data:
                print("No registered identities found.")
            else:
                print("Registered Identities:")
                for name in data.keys():
                    print(f"  - {name}")
    except Exception as e:
        print(f"Error reading encodings: {e}")

def register_face_cli(name):
    import cv2
    import face_recognition
    import pickle
    import system.paths as paths
    
    encodings_path = paths.get_encodings_path()
    faces_dir = paths.get_known_faces_dir()
    os.makedirs(faces_dir, exist_ok=True)
    
    print(f"Registering face for '{name}'...")
    print("Position yourself directly in front of the camera.")
    input("Press Enter to capture your photo...")
    
    print("Opening camera and capturing frame...")
    cap = cv2.VideoCapture(0, cv2.CAP_AVFOUNDATION)
    if not cap.isOpened():
        print("Error: Could not open camera.")
        return
        
    # Warm up camera to let auto-exposure adjust
    for _ in range(10):
        cap.read()
        time.sleep(0.05)
        
    ret, frame = cap.read()
    cap.release()
    
    if not ret or frame is None:
        print("Error: Failed to capture frame from camera.")
        return
        
    rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    
    print("Analyzing captured photo for face registration...")
    locs = face_recognition.face_locations(rgb_frame, model="hog")
    if not locs:
        print("Error: No face detected. Please ensure you are visible and there is good lighting.")
        return
    if len(locs) > 1:
        print("Error: Multiple faces detected. Please make sure only one person is in the frame.")
        return
        
    encs = face_recognition.face_encodings(rgb_frame, locs)
    if encs:
        data = {}
        if os.path.exists(encodings_path):
            try:
                with open(encodings_path, "rb") as f:
                    data = pickle.load(f)
            except Exception:
                pass
        
        data[name] = encs[0]
        os.makedirs(os.path.dirname(encodings_path), exist_ok=True)
        with open(encodings_path, "wb") as f:
            pickle.dump(data, f)
            
        img_path = os.path.join(faces_dir, f"{name}.jpg")
        cv2.imwrite(img_path, frame)
        print(f"Success: Biometric profile for '{name}' secured! Photo saved to: {img_path}")
    else:
        print("Error: Failed to encode face.")

def remove_identity(name):
    import pickle
    import system.paths as paths
    encodings_path = paths.get_encodings_path()
    faces_dir = paths.get_known_faces_dir()
    if not os.path.exists(encodings_path):
        print("No registered identities found.")
        return
    try:
        with open(encodings_path, "rb") as f:
            data = pickle.load(f)
        if name in data:
            del data[name]
            with open(encodings_path, "wb") as f:
                pickle.dump(data, f)
            img_path = os.path.join(faces_dir, f"{name}.jpg")
            if os.path.exists(img_path):
                os.remove(img_path)
            print(f"Identity '{name}' successfully removed.")
        else:
            print(f"Identity '{name}' not found.")
    except Exception as e:
        print(f"Error updating encodings: {e}")

def handle_config(args):
    import system.paths as paths
    from dotenv import load_dotenv, set_key
    env_path = paths.get_env_path()
    load_dotenv(env_path)
    
    if len(args) == 0 or args[0] == "list":
        print("Current Configurations:")
        print(f"  VISIONSIGHT_CAMERA       = {os.getenv('VISIONSIGHT_CAMERA', '0')}")
        print(f"  VISIONSIGHT_TOLERANCE    = {os.getenv('VISIONSIGHT_TOLERANCE', '0.55')}")
        print(f"  VISIONSIGHT_AUTO_UNLOCK  = {os.getenv('VISIONSIGHT_AUTO_UNLOCK', 'true')}")
        print(f"  VISIONSIGHT_COOLDOWN     = {os.getenv('VISIONSIGHT_COOLDOWN', '10')}")
        print(f"  VISIONSIGHT_FPS          = {os.getenv('VISIONSIGHT_FPS', 'Medium')}")
        print(f"  VISIONSIGHT_RESOLUTION   = {os.getenv('VISIONSIGHT_RESOLUTION', '640x480')}")
    elif args[0] == "set" and len(args) >= 3:
        key = args[1].upper()
        if not key.startswith("VISIONSIGHT_"):
            key = "VISIONSIGHT_" + key
        val = args[2]
        set_key(env_path, key, val)
        print(f"Config updated: {key} = {val}")
    else:
        print("Usage:")
        print("  visionsight config list          List all config values")
        print("  visionsight config set <key> <val>  Update a config value")

def view_logs():
    import system.paths as paths
    log_path = paths.get_log_path()
    if not os.path.exists(log_path):
        print("No log file found.")
        return
    try:
        with open(log_path, 'r') as f:
            lines = f.readlines()
        print("Recent logs (last 20 lines):")
        for line in lines[-20:]:
            print(line.strip())
    except Exception as e:
        print(f"Error reading logs: {e}")

def test_recognition():
    from face_auth.verify import FaceVerifier
    from system.lock import SystemController
    print("Starting one-time CLI authentication test (Headless Mode)...")
    verifier = FaceVerifier(headless=True)
    result = verifier.authenticate_once(SystemController(), use_esc_hook=True, defer_unlock=True)
    if result == "success":
        print(f"\n✅ Test Successful: Authenticated as '{verifier.auth_name}'!")
    elif result == "rejected":
        print("\n🛑 Test Aborted by user.")
    else:
        print(f"\n⚠️ Test Finished. Status: {result}")

def install_global_cli():
    script_path = os.path.join(BASE_DIR, "visionsight")
    dest_dir = "/usr/local/bin"
    dest_path = os.path.join(dest_dir, "visionsight")
    
    # ── Step 1: Global symlink ────────────────────────────────────────────────
    print(f"Installing visionsight CLI to {dest_path}...")
    symlink_ok = False
    try:
        if not os.path.exists(dest_dir):
            print(f"Directory {dest_dir} does not exist. Creating it...")
            os.makedirs(dest_dir, exist_ok=True)
            
        if os.path.exists(dest_path) or os.path.islink(dest_path):
            os.remove(dest_path)
            
        os.symlink(script_path, dest_path)
        print("✅ Symlink created: visionsight is now available as a global command.")
        symlink_ok = True
    except Exception as e:
        print(f"\n⚠️ Error installing symlink: {e}")
        print("Please try running with sudo or manually create the symlink:")
        print(f"  sudo ln -sf {script_path} {dest_path}")

    # ── Step 2: Write `alias vs="visionsight"` to ~/.zshrc ───────────────────
    # Because the symlink lands in /usr/local/bin (which is on $PATH),
    # the alias needs NO hardcoded path — it works for anyone on any machine.
    alias_line = 'alias vs="visionsight"'
    zshrc_path = os.path.expanduser("~/.zshrc")
    try:
        # Read existing content (create file if missing)
        existing = ""
        if os.path.exists(zshrc_path):
            with open(zshrc_path, "r") as f:
                existing = f.read()

        if alias_line in existing:
            print(f"✅ Alias already present in {zshrc_path} — skipping.")
        else:
            with open(zshrc_path, "a") as f:
                f.write(f"\n# VisionSight — short alias (added by visionsight install)\n{alias_line}\n")
            print(f"✅ Alias added to {zshrc_path}.")
            print("   Run 'source ~/.zshrc' (or open a new terminal) to activate 'vs'.")
    except Exception as e:
        print(f"⚠️ Could not write alias to {zshrc_path}: {e}")
        print(f"  Add this line manually:\n    {alias_line}")

    if symlink_ok:
        print("\n🎉 Installation complete!")
        print("  • Type 'visionsight' from anywhere to launch VisionSight.")
        print("  • Type 'vs' (after sourcing ~/.zshrc) as a short alias.")

def main():
    if len(sys.argv) < 2:
        launch_gui(minimized=False)
        return
        
    cmd = sys.argv[1].lower()
    if cmd == "setup":
        run_setup()
    elif cmd == "start":
        launch_gui(minimized=True)
    elif cmd == "stop":
        stop_daemon()
    elif cmd == "gui":
        launch_gui(minimized=False)
    elif cmd == "status":
        print_status()
    elif cmd in ("version", "--version", "-v"):
        print("VisionSight Version 5.0")
    elif cmd == "list":
        list_identities()
    elif cmd == "register":
        if len(sys.argv) < 3:
            print("Error: Name required for registration.")
            print("Usage: visionsight register <name>")
            return
        register_face_cli(sys.argv[2])
    elif cmd in ("remove", "delete"):
        if len(sys.argv) < 3:
            print("Error: Name required for removal.")
            print("Usage: visionsight remove <name>")
            return
        remove_identity(sys.argv[2])
    elif cmd == "config":
        handle_config(sys.argv[2:])
    elif cmd == "logs":
        view_logs()
    elif cmd == "test":
        test_recognition()
    elif cmd == "install":
        install_global_cli()
    elif cmd in ("--help", "-h", "help"):
        print("VisionSight CLI Helper")
        print("Usage:")
        print("  visionsight          Launch VisionSight dashboard GUI")
        print("  visionsight gui      Launch VisionSight dashboard GUI")
        print("  visionsight setup    Run keychain password setup wizard")
        print("  visionsight start    Start protection (runs minimized in tray)")
        print("  visionsight stop     Stop protection daemon")
        print("  visionsight status   Show process state and active PIDs")
        print("  visionsight version  Show version information")
        print("  visionsight list     List all registered identities")
        print("  visionsight register <name>  Register a new face from the terminal")
        print("  visionsight remove <name>    Remove a registered identity")
        print("  visionsight config   List or set configurations")
        print("  visionsight logs     View recent logs")
        print("  visionsight test     Perform a one-time face recognition test")
        print("  visionsight install  Install globally: adds 'visionsight' to PATH + 'vs' alias to ~/.zshrc")
        
        print("\nGlobal Shell Integration:")
        print("  Run 'visionsight install' once to set everything up for your user:")
        print("    • Symlinks visionsight → /usr/local/bin  (works from any directory)")
        print("    • Adds 'alias vs=\"visionsight\"' to ~/.zshrc  (works for any user on any machine)")
        print("  Then reload your shell:")
        print("    source ~/.zshrc")
    else:
        print(f"Unknown command: {cmd}")
        print("Run 'visionsight help' for usage details.")

if __name__ == "__main__":
    main()
